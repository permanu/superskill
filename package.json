{
  "name": "superskill",
  "version": "0.2.0",
  "description": "Universal agentic knowledge base + context optimizer + skill marketplace for AI tools",
  "type": "module",
  "main": "dist/mcp-server.js",
  "bin": {
    "superskill": "dist/mcp-server.js",
    "superskill-cli": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/mcp-server.js",
      "default": "./dist/mcp-server.js"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start:mcp": "node dist/mcp-server.js",
    "start:cli": "node dist/cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node dist/setup/postinstall.js || true",
    "preuninstall": "node dist/setup/preuninstall.js || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Permanu (Atharva Pandey)",
  "repository": {
    "type": "git",
    "url": "https://github.com/permanu/superskill.git"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "superskill",
    "knowledge-base",
    "ai",
    "cli",
    "agentic",
    "coding-agent",
    "claude",
    "cursor",
    "opencode",
    "codex"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
